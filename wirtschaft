                    <span>СЛЕДУЮЩЕЕ</span>
                    <i class="fa-solid fa-arrow-right"></i>
                </button>
            </div>
            
            <!-- STATS MODE -->
            <div id="mode-stats" class="mode-section hidden">
                <div class="mb-8 text-center">
                    <div class="section-header mb-1">ОБЩИЙ ПРОГРЕСС</div>
