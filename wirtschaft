                    </div>
                </div>
                
                <!-- Options -->
                <div id="quiz-options" class="space-y-3 mb-6">
                    <!-- Populated by JS -->
                </div>
                
                <button onclick="nextQuizQuestion()" id="quiz-next-btn"
