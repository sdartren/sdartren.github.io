        // State
        let progress = {};
        let mode = 'cards';
        let direction = 'de-ru';
        let currentIdx = 0;
        let flipped = false;
        let filter = 'all';
        let order = VOCAB.map(c => c.id);
        let quizCard = null;
        let quizOptions = [];
        let quizAnswered = null;
        let quizStreak = 0;
        
        // Load from localStorage
        function loadProgress() {
            try {
                const saved = localStorage.getItem('wirtschaft-progress');
                if (saved) progress = JSON.parse(saved);
                
                const settings = localStorage.getItem('wirtschaft-settings');
                if (settings) {
                    const s = JSON.parse(settings);
                    if (s.direction) direction = s.direction;
                }
            } catch (e) {}
        }
        
        function saveProgress() {
            try {
                localStorage.setItem('wirtschaft-progress', JSON.stringify(progress));
            } catch (e) {}
        }
        
        function saveSettings() {
            try {
                localStorage.setItem('wirtschaft-settings', JSON.stringify({ direction }));
            } catch (e) {}
        }
        
        function getStats() {
            let known = 0, learning = 0, fresh = 0;
            VOCAB.forEach(c => {
                const s = progress[c.id]?.status;
                if (s === 'known') known++;
                else if (s === 'learning') learning++;
                else fresh++;
            });
            return { known, learning, fresh, total: VOCAB.length };
        }
        
        function updateHeader() {
            const stats = getStats();
            document.getElementById('header-stats').innerHTML = `${stats.known}/${stats.total}`;
            
            const pct = Math.round((stats.known / stats.total) * 100);
            document.getElementById('progress-text').innerHTML = `${pct}%`;
            document.getElementById('progress-bar').style.width = `${pct}%`;
        }
        
        function getFilteredIds() {
            if (filter === 'unlearned') {
                return order.filter(id => (progress[id]?.status || 'new') !== 'known');
            }
            if (filter === 'difficult') {
                return order.filter(id => (progress[id]?.wrongCount || 0) >= 2);
            }
            return order;
        }
        
        function getCurrentCard() {
            const ids = getFilteredIds();
            if (ids.length === 0) return VOCAB[0];
            const idx = currentIdx % ids.length;
            return VOCAB.find(c => c.id === ids[idx]);
        }
        
        function renderCard() {
            const card = getCurrentCard();
            if (!card) return;
            
            const ids = getFilteredIds();
            const idx = currentIdx % ids.length;
            
            document.getElementById('card-counter').textContent = 
                `${String(idx + 1).padStart(2, '0')} / ${String(ids.length).padStart(2, '0')}`;
            
            const cardProgress = progress[card.id] || { status: 'new', correctCount: 0, wrongCount: 0 };
            const status = cardProgress.status || 'new';
            
            const statusLabels = { new: 'Новое', learning: 'Изучается', known: 'Выучено' };
            const statusColors = { new: '#776B5A', learning: '#B8893A', known: '#3F5C3B' };
            
            const frontText = direction === 'de-ru' ? card.de : card.ru;
            const backText = direction === 'de-ru' ? card.ru : card.de;
            const frontLang = direction === 'de-ru' ? 'DE' : 'RU';
            const backLang = direction === 'de-ru' ? 'RU' : 'DE';
            
            document.getElementById('card-id-front').textContent = String(card.id).padStart(2, '0');
            document.getElementById('card-lang-front').textContent = frontLang;
            document.getElementById('card-text-front').innerHTML = frontText;
            document.getElementById('status-label-front').textContent = statusLabels[status];
            document.getElementById('card-status-front').style.color = statusColors[status];
            document.getElementById('card-status-front').style.borderColor = statusColors[status] + '40';
            
            document.getElementById('card-id-back').textContent = String(card.id).padStart(2, '0');
            document.getElementById('card-lang-back').textContent = backLang;
            document.getElementById('card-text-back').innerHTML = backText;
            
            const flipContainer = document.getElementById('flashcard');
            flipContainer.classList.remove('flipped');
            flipped = false;
            
            const actions = document.getElementById('action-buttons');
            actions.style.opacity = '0.35';
            actions.style.pointerEvents = 'none';
        }
        
        function flipCard() {
            const flipContainer = document.getElementById('flashcard');
            flipped = !flipped;
            
            if (flipped) {
                flipContainer.classList.add('flipped');
                setTimeout(() => {
                    document.getElementById('action-buttons').style.opacity = '1';
                    document.getElementById('action-buttons').style.pointerEvents = 'auto';
                }, 300);
            } else {
                flipContainer.classList.remove('flipped');
                document.getElementById('action-buttons').style.opacity = '0.35';
                document.getElementById('action-buttons').style.pointerEvents = 'none';
            }
        }
        
        function markCard(result) {
            const card = getCurrentCard();
            if (!card) return;
            
            const cur = progress[card.id] || { status: 'new', correctCount: 0, wrongCount: 0 };
            let { correctCount = 0, wrongCount = 0 } = cur;
            let newStatus = cur.status || 'new';
            
            if (result === 'known') {
                correctCount++;
                newStatus = correctCount >= 2 ? 'known' : 'learning';
            } else if (result === 'hard') {
                newStatus = 'learning';
            } else {
                wrongCount++;
                correctCount = Math.max(0, correctCount - 1);
                newStatus = 'learning';
            }
            
            progress[card.id] = { status: newStatus, correctCount, wrongCount };
            saveProgress();
            updateHeader();
            
            setTimeout(() => {
                nextCard();
            }, 180);
        }
        
        function nextCard() {
            const ids = getFilteredIds();
            currentIdx = (currentIdx + 1) % Math.max(1, ids.length);
            renderCard();
        }
        
        function prevCard() {
            const ids = getFilteredIds();
            currentIdx = (currentIdx - 1 + ids.length) % Math.max(1, ids.length);
            renderCard();
        }
        
        function setFilter(newFilter) {
            filter = newFilter;
            
            document.getElementById('filter-all').className = 
                `px-4 py-1 text-xs font-medium rounded-2xl border whitespace-nowrap ${newFilter === 'all' ? 'border-[#1A1612] bg-[#1A1612] text-white' : 'border-[#D6CCB5] bg-white'}`;
            
            document.getElementById('filter-unlearned').className = 
                `px-4 py-1 text-xs font-medium rounded-2xl border whitespace-nowrap ${newFilter === 'unlearned' ? 'border-[#1A1612] bg-[#1A1612] text-white' : 'border-[#D6CCB5] bg-white'}`;
            
            document.getElementById('filter-difficult').className = 
                `px-4 py-1 text-xs font-medium rounded-2xl border whitespace-nowrap ${newFilter === 'difficult' ? 'border-[#1A1612] bg-[#1A1612] text-white' : 'border-[#D6CCB5] bg-white'}`;
            
            currentIdx = 0;
            renderCard();
        }
        
        function toggleDirection() {
            direction = direction === 'de-ru' ? 'ru-de' : 'de-ru';
            saveSettings();
            
            const label = direction === 'de-ru' ? 'DE → RU' : 'RU → DE';
            document.getElementById('dir-label').textContent = label;
            document.getElementById('quiz-dir-label').textContent = label;
            
            if (mode === 'cards') {
                renderCard();
            } else if (mode === 'quiz' && quizCard) {
                renderQuiz();
            }
        }
        
        function reshuffleCards() {
            order = [...VOCAB].sort(() => Math.random() - 0.5).map(c => c.id);
            currentIdx = 0;
            renderCard();
            
            const toast = document.createElement('div');
            toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 bg-[#1A1612] text-white px-5 py-2 rounded-2xl text-xs flex items-center gap-2 shadow-xl';
            toast.innerHTML = `<i class="fa-solid fa-random"></i> <span>Порядок перемешан</span>`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 1600);
        }
        
        function buildQuiz() {
            const pool = VOCAB.filter(c => (progress[c.id]?.status || 'new') !== 'known');
            const source = pool.length >= 4 ? pool : VOCAB;
            
            quizCard = source[Math.floor(Math.random() * source.length)];
            
            const distractorPool = VOCAB.filter(c => c.id !== quizCard.id);
            const distractors = [...distractorPool].sort(() => Math.random() - 0.5).slice(0, 3);
            quizOptions = [...distractors, quizCard].sort(() => Math.random() - 0.5);
            
            quizAnswered = null;
            renderQuiz();
        }
        
        function renderQuiz() {
            if (!quizCard) return;
            
            const prompt = direction === 'de-ru' ? quizCard.de : quizCard.ru;
            document.getElementById('quiz-prompt').innerHTML = prompt;
            
            const container = document.getElementById('quiz-options');
            container.innerHTML = '';
            
            quizOptions.forEach((opt, i) => {
                const text = direction === 'de-ru' ? opt.ru : opt.de;
                const isAnswered = quizAnswered !== null;
                const isCorrect = opt.id === quizCard.id;
                const wasPicked = quizAnswered?.id === opt.id;
                
                let classes = 'option-btn w-full text-left px-5 py-4 rounded-2xl border flex items-start gap-3 bg-[#F8F3E6] border-[#D6CCB5]';
                
                if (isAnswered) {
                    if (isCorrect) {
                        classes = 'option-btn w-full text-left px-5 py-4 rounded-2xl border flex items-start gap-3 bg-[#3F5C3B] border-[#3F5C3B] text-white';
                    } else if (wasPicked) {
                        classes = 'option-btn w-full text-left px-5 py-4 rounded-2xl border flex items-start gap-3 bg-[#A8201A] border-[#A8201A] text-white shake';
                    } else {
                        classes = 'option-btn w-full text-left px-5 py-4 rounded-2xl border flex items-start gap-3 bg-[#F8F3E6] border-[#D6CCB5] opacity-60 text-[#776B5A]';
                    }
                }
                
                const btn = document.createElement('button');
                btn.className = classes;
                btn.innerHTML = `
                    <span class="mono text-xs pt-0.5 opacity-60 w-5">${String.fromCharCode(65 + i)}</span>
                    <span class="flex-1">${text}</span>
                    ${isAnswered && isCorrect ? '<i class="fa-solid fa-check pt-1"></i>' : ''}
                    ${isAnswered && wasPicked && !isCorrect ? '<i class="fa-solid fa-times pt-1"></i>' : ''}
                `;
                
                if (!isAnswered) {
                    btn.onclick = () => handleQuizAnswer(opt.id);
                }
                
                container.appendChild(btn);
            });
            
            const nextBtn = document.getElementById('quiz-next-btn');
            if (quizAnswered !== null) {
                nextBtn.classList.remove('hidden');
            } else {
                nextBtn.classList.add('hidden');
            }
            
            document.getElementById('quiz-streak').textContent = quizStreak;
            document.getElementById('quiz-streak').style.color = quizStreak > 0 ? '#3F5C3B' : '#776B5A';
        }
        
        function handleQuizAnswer(optionId) {
            if (quizAnswered !== null || !quizCard) return;
            
            const correct = optionId === quizCard.id;
            quizAnswered = { id: optionId, correct };
            
            if (correct) {
                const cur = progress[quizCard.id] || { status: 'new', correctCount: 0, wrongCount: 0 };
                let correctCount = (cur.correctCount || 0) + 1;
                const newStatus = correctCount >= 2 ? 'known' : 'learning';
                progress[quizCard.id] = { ...cur, status: newStatus, correctCount };
                quizStreak++;
            } else {
                const cur = progress[quizCard.id] || { status: 'new', correctCount: 0, wrongCount: 0 };
                progress[quizCard.id] = { 
                    ...cur, 
                    status: 'learning', 
                    wrongCount: (cur.wrongCount || 0) + 1,
                    correctCount: Math.max(0, (cur.correctCount || 0) - 1)
                };
                quizStreak = 0;
            }
            
            saveProgress();
            updateHeader();
            renderQuiz();
        }
        
        function nextQuizQuestion() {
            buildQuiz();
        }
        
        function renderStats() {
            const stats = getStats();
            
            document.getElementById('stats-known').textContent = stats.known;
            document.getElementById('stats-percent').innerHTML = 
                `${Math.round((stats.known / stats.total) * 100)}% слов выучено`;
            
            const total = stats.total;
            document.getElementById('dist-known').style.width = `${(stats.known / total) * 100}%`;
            document.getElementById('dist-learning').style.width = `${(stats.learning / total) * 100}%`;
            document.getElementById('dist-fresh').style.width = `${(stats.fresh / total) * 100}%`;
            
            document.getElementById('dist-known-count').textContent = stats.known;
            document.getElementById('dist-learning-count').textContent = stats.learning;
            document.getElementById('dist-fresh-count').textContent = stats.fresh;
            
            document.getElementById('unlearned-count').textContent = stats.fresh + stats.learning;
            
            const difficult = VOCAB.filter(c => (progress[c.id]?.wrongCount || 0) >= 2);
            document.getElementById('difficult-count').textContent = difficult.length;
            
            const list = document.getElementById('difficult-list');
            list.innerHTML = '';
            
            if (difficult.length === 0) {
                const empty = document.createElement('div');
                empty.className = 'text-xs text-[#776B5A] italic px-1';
                empty.textContent = 'Пока нет сложных слов';
                list.appendChild(empty);
            } else {
                difficult.slice(0, 4).forEach(c => {
                    const div = document.createElement('div');
                    div.className = 'bg-white border border-[#D6CCB5] rounded-2xl px-4 py-3 text-sm';
                    div.innerHTML = `
                        <div class="display-font text-sm leading-tight">${c.de}</div>
                        <div class="text-xs text-[#776B5A] mt-1">${c.ru}</div>
                    `;
                    list.appendChild(div);
                });
            }
        }
        
        function goToUnlearned() {
            switchMode('cards');
            setFilter('unlearned');
        }
        
        function resetAllProgress() {
            if (!confirm('Сбросить весь прогресс?')) return;
            
            progress = {};
            localStorage.removeItem('wirtschaft-progress');
            quizStreak = 0;
            
            updateHeader();
            
            if (mode === 'cards') renderCard();
            else if (mode === 'stats') renderStats();
            
            const toast = document.createElement('div');
            toast.className = 'fixed bottom-6 left-1/2 -translate-x-1/2 bg-[#A8201A] text-white px-5 py-2 rounded-2xl text-xs flex items-center gap-2 shadow-xl';
            toast.innerHTML = `Прогресс сброшен`;
            document.body.appendChild(toast);
            setTimeout(() => toast.remove(), 1800);
        }
        
        function switchMode(newMode) {
            mode = newMode;
            
            document.querySelectorAll('.mode-section').forEach(el => el.classList.add('hidden'));
            document.getElementById(`mode-${newMode}`).classList.remove('hidden');
            
            document.querySelectorAll('[id^="tab-"]').forEach(tab => {
                tab.classList.remove('active', 'bg-[#1A1612]', 'text-white');
                tab.classList.add('bg-white/50');
                
                if (tab.id === `tab-${newMode}`) {
                    tab.classList.add('active', 'bg-[#1A1612]', 'text-white');
                    tab.classList.remove('bg-white/50');
                }
            });
            
            if (newMode === 'cards') {
                renderCard();
            } else if (newMode === 'quiz') {
                if (!quizCard) buildQuiz();
                else renderQuiz();
            } else if (newMode === 'stats') {
                renderStats();
            }
        }
        
        function setupKeyboard() {
            document.addEventListener('keydown', (e) => {
                if (mode !== 'cards') return;
                
                if (e.key === ' ' || e.key === 'Enter') {
                    e.preventDefault();
                    const flipEl = document.getElementById('flashcard');
                    if (!flipped) {
                        flipCard();
                    } else {
                        markCard('known');
                    }
                }
                
                if (e.key === 'ArrowRight') nextCard();
                if (e.key === 'ArrowLeft') prevCard();
                
                if (e.key.toLowerCase() === 'k') markCard('known');
                if (e.key.toLowerCase() === 'h') markCard('hard');
                if (e.key.toLowerCase() === 'u') markCard('unknown');
            });
        }
        
        function init() {
            initTailwind();
            loadProgress();
            updateHeader();
            
            order = VOCAB.map(c => c.id);
            
            document.getElementById('mode-cards').classList.remove('hidden');
            document.getElementById('tab-cards').classList.add('active', 'bg-[#1A1612]', 'text-white');
            
            const dirLabel = direction === 'de-ru' ? 'DE → RU' : 'RU → DE';
            document.getElementById('dir-label').textContent = dirLabel;
            document.getElementById('quiz-dir-label').textContent = dirLabel;
            
            renderCard();
            setupKeyboard();
            
            document.getElementById('filter-all').classList.add('border-[#1A1612]', 'bg-[#1A1612]', 'text-white');
            
            console.log('%c[WIRTSCHAFT] GitHub Pages версия загружена', 'color:#3F5C3B');
        }
        
        window.onload = init;
    </script>
</body>
</html>