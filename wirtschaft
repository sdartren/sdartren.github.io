<!DOCTYPE html>
<html lang="ru">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no">
    <meta name="apple-mobile-web-app-capable" content="yes">
    <meta name="apple-mobile-web-app-status-bar-style" content="black-translucent">
    <meta name="apple-mobile-web-app-title" content="Wirtschaft">
    <meta name="theme-color" content="#EFE7D6">
    <title>Wirtschaft • Словарь</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.1/css/all.min.css">
    <style>
        @import url('https://fonts.googleapis.com/css2?family=Playfair+Display:wght@700&amp;family=Inter:wght@400;500;600&amp;display=swap');
        
        :root {
            --bg: #EFE7D6;
            --paper: #F8F3E6;
            --ink: #1A1612;
            --red: #A8201A;
            --ochre: #B8893A;
            --muted: #776B5A;
            --line: #D6CCB5;
            --green: #3F5C3B;
        }
        
        body {
            font-family: 'Inter', system-ui, -apple-system, BlinkMacSystemFont, sans-serif;
            background: var(--bg);
            color: var(--ink);
            -webkit-tap-highlight-color: transparent;
        }
        
        .display-font {
            font-family: 'Playfair Display', Georgia, serif;
            font-weight: 700;
            font-style: italic;
        }

        .mono {
            font-family: ui-monospace, SFMono-Regular, Menlo, Monaco, Consolas, "Liberation Mono", "Courier New", monospace;
        }

        .card-flip-container {
            perspective: 1200px;
            height: 340px;
        }

        .card-flip {
            width: 100%;
            height: 100%;
            position: relative;
            transform-style: preserve-3d;
            transition: transform 0.6s cubic-bezier(0.23, 1.0, 0.32, 1);
        }

        .card-flip.flipped {
            transform: rotateY(180deg);
        }

        .card-face {
            position: absolute;
            inset: 0;
            backface-visibility: hidden;
            -webkit-backface-visibility: hidden;
            border-radius: 20px;
            box-shadow: 0 10px 30px -15px rgba(26, 22, 18, 0.2);
        }

        .card-back {
            transform: rotateY(180deg);
        }

        .grain {
            background-image: radial-gradient(circle at 1px 1px, rgba(26,22,18,0.035) 1px, transparent 0);
            background-size: 3px 3px;
        }

        .vocab-card {
            box-shadow: 0 1px 0 rgba(26,22,18,0.04), 
                       0 20px 40px -20px rgba(26,22,18,0.25);
        }

        .section-header {
            font-size: 13px;
            letter-spacing: 0.08em;
            text-transform: uppercase;
            font-weight: 600;
            color: var(--muted);
        }

        .nav-tab {
            transition: all 0.2s cubic-bezier(0.4, 0, 0.2, 1);
        }

        .nav-tab.active {
            background: var(--ink);
            color: var(--paper);
            box-shadow: 0 4px 12px -2px rgba(26,22,18,0.3);
        }

        .option-btn {
            transition: all 0.15s ease;
            font-size: 15px;
            line-height: 1.35;
        }

        .option-btn:active {
            transform: scale(0.985);
        }

        .action-btn {
            transition: transform 0.1s ease, box-shadow 0.1s ease;
        }

        .action-btn:active {
            transform: scale(0.96);
        }

        .fade-in {
            animation: fadeInUp 0.4s ease forwards;
        }

        @keyframes fadeInUp {
            from { opacity: 0; transform: translateY(12px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .stat-number {
            font-size: 64px;
            line-height: 1;
            font-weight: 700;
            font-family: 'Playfair Display', Georgia, serif;
        }

        .progress-bar {
            height: 4px;
            background: var(--line);
            border-radius: 9999px;
            overflow: hidden;
        }

        .vocab-text {
            font-size: 22px;
            line-height: 1.3;
            font-weight: 500;
        }

        .small-vocab-text {
            font-size: 19px;
            line-height: 1.35;
        }
    </style>
</head>
<body class="ios-safe-area">
    <div class="max-w-md mx-auto min-h-screen flex flex-col">
        <!-- Header -->
        <div class="sticky top-0 z-50 bg-[#EFE7D6] px-5 pt-5 pb-3 border-b border-[#D6CCB5]">
            <div class="flex items-end justify-between mb-1">
                <div>
                    <h1 class="display-font text-4xl tracking-tight text-[#1A1612]">Wirtschaft</h1>
                    <p class="text-[#776B5A] text-[13px] tracking-[0.02em]">Словарь по теме «Экономика»</p>
                </div>
                <div class="text-right">
                    <div id="header-stats" 
                         class="mono text-[11px] text-[#776B5A] font-medium tracking-[0.06em]">
                        0/82
                    </div>
                </div>
            </div>
            
            <!-- Global Progress -->
            <div class="mt-3 mb-1">
                <div class="flex items-center justify-between text-[10px] text-[#776B5A] mono mb-1 px-0.5">
                    <div>ПРОГРЕСС</div>
                    <div id="progress-text">0%</div>
                </div>
                <div class="progress-bar">
                    <div id="progress-bar" 
                         class="h-full bg-[#A8201A] transition-all duration-500 ease-out"
                         style="width: 0%"></div>
                </div>
            </div>
            
            <!-- Mode Tabs -->
            <div class="flex gap-1.5 mt-4 bg-white/50 p-1 rounded-2xl border border-[#D6CCB5]">
                <button onclick="switchMode('cards')" id="tab-cards"
                        class="nav-tab flex-1 flex items-center justify-center gap-2 py-2.5 px-3 rounded-xl text-sm font-semibold active:bg-[#1A1612] active:text-white">
                    <i class="fa-solid fa-layer-group text-base"></i>
                    <span>Карточки</span>
                </button>
                <button onclick="switchMode('quiz')" id="tab-quiz"
                        class="nav-tab flex-1 flex items-center justify-center gap-2 py-2.5 px-3 rounded-xl text-sm font-semibold">
                    <i class="fa-solid fa-brain text-base"></i>
                    <span>Тест</span>
                </button>
                <button onclick="switchMode('stats')" id="tab-stats"
                        class="nav-tab flex-1 flex items-center justify-center gap-2 py-2.5 px-3 rounded-xl text-sm font-semibold">
                    <i class="fa-solid fa-chart-bar text-base"></i>
                    <span>Прогресс</span>
                </button>
            </div>
        </div>

        <!-- Main Content -->
        <div class="flex-1 px-5 pt-5 pb-8" id="main-content">
            
            <!-- CARDS MODE -->
            <div id="mode-cards" class="mode-section">
                <!-- Controls -->
                <div class="flex items-center justify-between mb-4">
                    <div class="mono text-xs text-[#776B5A] tracking-[0.08em]">
                        <span id="card-counter">01 / 82</span>
                    </div>
                    
                    <div class="flex items-center gap-2">
                        <!-- Direction Toggle -->
                        <button onclick="toggleDirection()" 
                                class="flex items-center gap-1.5 px-3 py-1.5 text-xs border border-[#D6CCB5] rounded-xl bg-white hover:bg-[#F8F3E6]">
                            <span id="dir-label" class="mono font-medium tracking-wider">DE → RU</span>
                            <i class="fa-solid fa-exchange-alt text-[#B8893A]"></i>
                        </button>
                        
                        <!-- Shuffle -->
                        <button onclick="reshuffleCards()" 
                                class="px-3 py-1.5 text-xs border border-[#D6CCB5] rounded-xl bg-white flex items-center justify-center">
                            <i class="fa-solid fa-random text-[#776B5A]"></i>
                        </button>
                    </div>
                </div>
                
                <!-- Filter Chips -->
                <div class="flex gap-2 mb-5 overflow-x-auto pb-1">
                    <button onclick="setFilter('all')" id="filter-all"
                            class="px-4 py-1 text-xs font-medium rounded-2xl border border-[#1A1612] bg-[#1A1612] text-white whitespace-nowrap">
                        Все
                    </button>
                    <button onclick="setFilter('unlearned')" id="filter-unlearned"
                            class="px-4 py-1 text-xs font-medium rounded-2xl border border-[#D6CCB5] bg-white whitespace-nowrap">
                        Не выучено
                    </button>
                    <button onclick="setFilter('difficult')" id="filter-difficult"
                            class="px-4 py-1 text-xs font-medium rounded-2xl border border-[#D6CCB5] bg-white whitespace-nowrap">
                        Сложные
                    </button>
                </div>
                
                <!-- Flashcard -->
                <div class="card-flip-container mb-6 mx-auto" style="max-width: 360px;">
                    <div id="flashcard" onclick="flipCard()" 
                         class="card-flip cursor-pointer w-full h-full">
                        
                        <!-- Front -->
                        <div id="card-front"
                             class="card-face grain vocab-card bg-[#F8F3E6] border border-[#D6CCB5] p-6 flex flex-col">
                            <div class="flex justify-between items-start mb-auto">
                                <div>
                                    <div class="mono text-[9px] text-[#776B5A] tracking-[0.1em]">№ <span id="card-id-front">01</span></div>
                                    <div id="card-lang-front" class="mono text-[9px] text-[#776B5A] tracking-[0.1em] mt-0.5">DE</div>
                                </div>
                                <div id="card-status-front" 
                                     class="px-2.5 py-0.5 text-[9px] mono font-medium rounded-full flex items-center gap-1.5"
                                     style="background: #F8F3E6; color: #776B5A; border: 1px solid #D6CCB5;">
                                    <span class="w-1.5 h-1.5 rounded-full" style="background: #776B5A;"></span>
                                    <span id="status-label-front">Новое</span>
                                </div>
                            </div>
                            
                            <div class="flex-1 flex items-center justify-center px-2">
                                <div id="card-text-front" 
                                     class="display-font text-center text-[#1A1612] leading-tight vocab-text">
                                </div>
                            </div>
                            
                            <div class="text-center text-[#776B5A] text-xs mt-auto tracking-wider">
                                НАЖМИТЕ, ЧТОБЫ ПЕРЕВЕРНУТЬ
                            </div>
                        </div>
                        
                        <!-- Back -->
                        <div id="card-back"
                             class="card-face grain vocab-card bg-[#1A1612] border border-[#1A1612] p-6 flex flex-col text-[#F8F3E6]">
                            <div class="flex justify-between items-start">
                                <div>
                                    <div class="mono text-[9px] text-white/50 tracking-[0.1em]">№ <span id="card-id-back">01</span></div>
                                    <div id="card-lang-back" class="mono text-[9px] text-white/50 tracking-[0.1em] mt-0.5">RU</div>
                                </div>
                                <div class="px-3 py-0.5 text-[9px] mono font-medium text-[#B8893A] tracking-widest">ПЕРЕВОД</div>
                            </div>
                            
                            <div class="flex-1 flex items-center justify-center px-2">
                                <div id="card-text-back" 
                                     class="display-font text-center text-[#F8F3E6] leading-tight small-vocab-text">
                                </div>
                            </div>
                            
                            <div class="text-center text-white/50 text-xs mt-auto tracking-wider">
                                ОЦЕНИТЕ, НАСКОЛЬКО ЗНАЕТЕ
                            </div>
                        </div>
                    </div>
                </div>
                
                <!-- Action Buttons -->
                <div id="action-buttons" class="grid grid-cols-3 gap-3 mb-5 opacity-40 pointer-events-none transition-all">
                    <button onclick="markCard('unknown')" 
                            class="action-btn flex flex-col items-center justify-center py-4 rounded-2xl border-2 border-[#A8201A] bg-white text-[#A8201A]">
                        <i class="fa-solid fa-times text-xl mb-1"></i>
                        <span class="text-xs font-semibold tracking-wider">НЕ ЗНАЮ</span>
                    </button>
                    
                    <button onclick="markCard('hard')" 
                            class="action-btn flex flex-col items-center justify-center py-4 rounded-2xl border-2 border-[#B8893A] bg-white text-[#B8893A]">
                        <i class="fa-solid fa-spa text-xl mb-1"></i>
                        <span class="text-xs font-semibold tracking-wider">СЛОЖНО</span>
                    </button>
                    
                    <button onclick="markCard('known')" 
                            class="action-btn flex flex-col items-center justify-center py-4 rounded-2xl border-2 border-[#3F5C3B] bg-white text-[#3F5C3B]">
                        <i class="fa-solid fa-check text-xl mb-1"></i>
                        <span class="text-xs font-semibold tracking-wider">ЗНАЮ</span>
                    </button>
                </div>
                
                <!-- Navigation -->
                <div class="flex gap-3">
                    <button onclick="prevCard()" 
                            class="flex-1 py-3.5 flex items-center justify-center gap-2 text-sm font-semibold border border-[#D6CCB5] rounded-2xl bg-white">
                        <i class="fa-solid fa-chevron-left"></i>
                        <span>Назад</span>
                    </button>
                    <button onclick="nextCard()" 
                            class="flex-1 py-3.5 flex items-center justify-center gap-2 text-sm font-semibold border border-[#D6CCB5] rounded-2xl bg-white">
                        <span>Дальше</span>
                        <i class="fa-solid fa-chevron-right"></i>
                    </button>
                </div>
            </div>
            
            <!-- QUIZ MODE -->
