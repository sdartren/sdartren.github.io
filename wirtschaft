                        <div id="stats-known" class="stat-number text-[#1A1612]">0</div>
                        <div class="text-3xl text-[#776B5A]">/ 82</div>
                    </div>
                    <div id="stats-percent" class="text-[#776B5A] text-sm">0% слов выучено</div>
                </div>
                
                <!-- Distribution -->
                <div class="mb-8">
                    <div class="h-3 bg-[#D6CCB5] rounded-full overflow-hidden flex mb-3">
                        <div id="dist-known" class="bg-[#3F5C3B] h-full transition-all" style="width: 0%"></div>
                        <div id="dist-learning" class="bg-[#B8893A] h-full transition-all" style="width: 0%"></div>
                        <div id="dist-fresh" class="bg-[#776B5A] h-full transition-all" style="width: 100%"></div>
                    </div>
                    
                    <div class="flex justify-between text-xs px-1">
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-[#3F5C3B]"></span>
                            <span class="text-[#776B5A]">Выучено <span id="dist-known-count" class="font-mono text-[#1A1612]">0</span></span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-[#B8893A]"></span>
                            <span class="text-[#776B5A]">Изучается <span id="dist-learning-count" class="font-mono text-[#1A1612]">0</span></span>
                        </div>
                        <div class="flex items-center gap-2">
                            <span class="w-3 h-3 rounded-full bg-[#776B5A]"></span>
                            <span class="text-[#776B5A]">Новое <span id="dist-fresh-count" class="font-mono text-[#1A1612]">82</span></span>
                        </div>
                    </div>
                </div>
                
                <!-- Quick actions -->
                <div class="grid grid-cols-2 gap-3 mb-8">
                    <button onclick="goToUnlearned()" 
                            class="bg-[#F8F3E6] border border-[#D6CCB5] rounded-2xl p-4 text-left hover:border-[#B8893A] transition-colors">
                        <div class="text-4xl font-bold text-[#1A1612]" id="unlearned-count">82</div>
                        <div class="text-xs text-[#776B5A] mt-1">повторить →</div>
                    </button>
                    
                    <button onclick="switchMode('quiz')" 
                            class="bg-[#1A1612] text-white rounded-2xl p-4 text-left">
                        <div class="text-3xl font-bold italic">Тест</div>
                        <div class="text-xs text-white/60 mt-1">проверить себя →</div>
                    </button>
                </div>
                
                <!-- Difficult words -->
                <div id="difficult-section" class="mb-6">
                    <div class="section-header mb-3 flex items-center justify-between">
                        <span>СЛОЖНЫЕ СЛОВА</span>
                        <span id="difficult-count" class="text-xs bg-[#A8201A] text-white px-2 py-px rounded">0</span>
                    </div>
                    <div id="difficult-list" class="space-y-2 text-sm">
                        <!-- Populated dynamically -->
                    </div>
                </div>
                
                <!-- Reset -->
                <button onclick="resetAllProgress()" 
                        class="w-full py-3 text-sm flex items-center justify-center gap-2 text-[#776B5A] border border-[#D6CCB5] rounded-2xl hover:bg-white">
                    <i class="fa-solid fa-undo text-xs"></i>
                    <span>Сбросить весь прогресс</span>
                </button>
                
                <div class="text-center mt-8 text-xs text-[#776B5A]">
                    <span class="display-font italic">Übung macht den Meister</span>
                </div>
            </div>
            
        </div>
    </div>

